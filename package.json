{
  "name": "cr-vc-reference-apps",
  "version": "0.1.0",
  "description": "Reference issuer + verifier apps for the Costa Rica SSI driving ecosystem",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
